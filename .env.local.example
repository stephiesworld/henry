# Copy this file to .env.local and fill in your keys.
# Both are OPTIONAL — HENRY runs in demo mode (realistic mock data + a canned
# assistant) when a key is missing, so you can click through everything first.

# Keepa API key — powers the ASIN tools (buy box, featured offers, price lows,
# variance). Get one at https://keepa.com/#!api  (paid subscription).
KEEPA_API_KEY=

# Keepa marketplace domain id (1 = amazon.com, 2 = .co.uk, 3 = .de, ...).
KEEPA_DOMAIN=1

# Anthropic API key — powers "Ask Henry" (Claude Opus 4.8 + web search).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=
